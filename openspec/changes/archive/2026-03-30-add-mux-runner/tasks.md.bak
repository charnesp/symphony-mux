### Task 1.N: Update `run_turn()` dispatcher (Test-First)

**File**: `tests/test_runner.py` then `stokowski/runner.py`

**Test First**:
```python
@pytest.mark.asyncio
async def test_run_turn_dispatches_to_mux():
    """Verify run_turn dispatches to mux runner."""
    from stokowski.runner import run_turn
    from unittest.mock import patch

    with patch("stokowski.runner.run_mux_turn") as mock_mux:
        mock_mux.return_value = RunAttempt(session_id="test")

        # This should fail until we add the mux case
        await run_turn(
            runner_type="mux",
            claude_cfg=ClaudeConfig(),
            hooks_cfg=HooksConfig(),
            prompt="test",
            workspace_path=Path("/tmp"),
            issue=Issue(title="", identifier="TEST-1"),
            attempt=RunAttempt(),
        )

        mock_mux.assert_called_once()
```

**Then Implementation** in `stokowski/runner.py`:
```python
async def run_turn(...):
    """Route to the correct runner based on runner_type."""
    if runner_type == "codex":
        return await run_codex_turn(...)
    elif runner_type == "mux":
        return await run_mux_turn(...)
    elif runner_type == "claude":
        return await run_agent_turn(...)
    else:
        raise ValueError(f"Unknown runner type: {runner_type}")
```

**Estimated**: 30 minutes

**Code Change**:
```python
async def run_turn(
    runner_type: str,
    claude_cfg: ClaudeConfig,
    hooks_cfg: HooksConfig,
    prompt: str,
    workspace_path: Path,
    issue: Issue,
    attempt: RunAttempt,
    on_event: EventCallback | None = None,
    on_pid: PidCallback | None = None,
    env: dict[str, str] | None = None,
) -> RunAttempt:
    """Route to the correct runner based on runner_type."""
    if runner_type == "codex":
        return await run_codex_turn(...)
    elif runner_type == "mux":                    # NEW
        return await run_mux_turn(...)
    elif runner_type == "claude":
        return await run_agent_turn(...)
    else:
        raise ValueError(f"Unknown runner type: {runner_type}")
```

